generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum PurchaseType {
  finished
  fabric
  raw_material
  packaging
  corporate_assets
  samples
  influencer_samples
  transportation
  advertisement
  office_expenses
  software
  feedback
  misc
  customer_refunds
}

enum EntryMode {
  catalog
  free_text
  link_finished
  special
}

enum RawMaterialMode {
  direct_purchase
  raw_materials_issued
}

enum POStatus {
  draft
  pending_approval
  approved
  approved_pending_rm_issuance
  rm_issued_pending_goods
  rejected
  partially_received
  goods_received
  payment_pending
  payment_approved
  paid
}

enum MovementType {
  grn
  sale
  sample
  production_in
  production_out
  rm_issued_to_vendor
  adjustment_add
  adjustment_reduce
  write_off
  opening
}

enum PermissionLevel {
  none
  view
  edit
}

enum UserStatus {
  active
  inactive
}

enum GoodsCondition {
  good
  damaged
  defective
}

enum AdjustmentType {
  addition
  reduction
  write_off_damaged
  write_off_expired
  opening
}

enum PaymentStatus {
  paid
  pending
  cod
}

enum ApprovalType {
  po_approval
  payment_approval
}

enum ApprovalAction {
  approved
  rejected
}

enum EntityType {
  in_house
  external
}

enum ExternalVendorType {
  payment_processor
  logistics
  other
}

enum OutflowType {
  sale
  sample
  production_consumption
  marketing
  other
}

enum ProductionType {
  in_house
  job_work
}

enum ProductionStatus {
  planned
  in_progress
  completed
  cancelled
}

// ============================================
// CORE TABLES
// ============================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  User[]
  purchaseTypes          PurchaseTypeConfig[]
  salesChannels          SalesChannel[]
  entities               Entity[]
  paymentModes           PaymentMode[]
  externalVendors        ExternalVendor[]
  suppliers              Supplier[]
  productCategories      ProductCategory[]
  products               Product[]
  purchaseOrders         PurchaseOrder[]
  grns                   GRN[]
  inventoryBatches       InventoryBatch[]
  stockLedger            StockLedger[]
  inventoryOutflows      InventoryOutflow[]
  stockAdjustments       StockAdjustment[]
  productions            Production[]
  payments               Payment[]
  marketplaceSettlements MarketplaceSettlement[]
  customerInvoices       CustomerInvoice[]
  customerCredits        CustomerCredit[]
  approvalAuditLogs      ApprovalAuditLog[]

  @@map("tenants")
}

model User {
  id             String     @id @default(cuid())
  tenantId       String
  supabaseUserId String?    @unique
  email          String     @unique
  name           String
  role           String     @default("user")
  isSuperAdmin   Boolean    @default(false)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  permissions UserPermission[]

  createdPurchaseOrders  PurchaseOrder[]    @relation("CreatedBy")
  approvedPurchaseOrders PurchaseOrder[]    @relation("ApprovedBy")
  createdGRNs            GRN[]              @relation("GRNCreatedBy")
  createdPayments        Payment[]          @relation("PaymentCreatedBy")
  approvedPayments       Payment[]          @relation("PaymentApprovedBy")
  createdProductions     Production[]       @relation("ProductionCreatedBy")
  approvalActions        ApprovalAuditLog[]
  stockAdjustments       StockAdjustment[]
  inventoryOutflows      InventoryOutflow[]

  @@index([tenantId])
  @@map("users")
}

model UserPermission {
  id              String          @id @default(cuid())
  userId          String
  module          String
  subModule       String?
  permissionLevel PermissionLevel @default(none)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module, subModule])
  @@map("user_permissions")
}

model PurchaseTypeConfig {
  id                String       @id @default(cuid())
  tenantId          String
  purchaseType      PurchaseType
  name              String
  prefix            String
  allowedEntryModes EntryMode[]
  trackInventory    Boolean      @default(false)
  requiresApproval  Boolean      @default(true)
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, purchaseType])
  @@map("purchase_types")
}

model SalesChannel {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  marketplaceSettlements MarketplaceSettlement[]
  inventoryOutflows      InventoryOutflow[]

  @@unique([tenantId, code])
  @@map("sales_channels")
}

model Entity {
  id         String     @id @default(cuid())
  tenantId   String
  name       String
  type       EntityType
  isExternal Boolean    @default(false)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  paymentModes      PaymentMode[]
  purchaseOrders    PurchaseOrder[]
  payments          Payment[]
  inventoryOutflows InventoryOutflow[]

  @@unique([tenantId, name])
  @@map("entities")
}

model PaymentMode {
  id        String   @id @default(cuid())
  entityId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entity   Entity    @relation(fields: [entityId], references: [id])
  payments Payment[]
  Tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  tenantId String?

  @@unique([entityId, name])
  @@map("payment_modes")
}

model ExternalVendor {
  id         String             @id @default(cuid())
  tenantId   String
  name       String
  code       String
  vendorType ExternalVendorType
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@unique([tenantId, code])
  @@map("external_vendors")
}

// ============================================
// SUPPLIER & PRODUCT TABLES
// ============================================

model Supplier {
  id                String   @id @default(cuid())
  tenantId          String
  name              String
  code              String
  email             String?
  phone             String?
  address           String?
  gstNumber         String?
  panNumber         String?
  bankName          String?
  bankAccountNumber String?
  bankIfscCode      String?
  paymentTerms      String?
  supplyCategories  String[] @default([])
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  contacts       SupplierContact[]
  pricings       SupplierPricing[]
  purchaseOrders PurchaseOrder[]
  payments       Payment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("suppliers")
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_contacts")
}

model SupplierPricing {
  id         String    @id @default(cuid())
  supplierId String
  productId  String
  unitPrice  Decimal   @db.Decimal(12, 2)
  currency   String    @default("INR")
  minQty     Int?
  validFrom  DateTime?
  validTo    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@map("supplier_pricing")
}

model ProductCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  level     Int      @default(1)
  parentId  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  sku         String
  name        String
  description String?
  categoryId  String?
  unit        String   @default("pcs")
  hsnCode     String?
  gstRate     Decimal? @db.Decimal(5, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  category            ProductCategory?     @relation(fields: [categoryId], references: [id])
  supplierPricings    SupplierPricing[]
  poLineItems         POLineItem[]
  poRmIssuanceItems   PORmIssuanceItem[]
  inventoryBatches    InventoryBatch[]
  stockLedger         StockLedger[]
  productionMaterials ProductionMaterial[]
  outflowItems        OutflowItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

// ============================================
// PURCHASE ORDER TABLES
// ============================================

model PurchaseOrder {
  id               String           @id @default(cuid())
  tenantId         String
  poNumber         String
  purchaseType     PurchaseType
  supplierId       String?
  entityId         String
  status           POStatus         @default(draft)
  entryMode        EntryMode
  rawMaterialMode  RawMaterialMode?
  totalAmount      Decimal          @default(0) @db.Decimal(14, 2)
  taxAmount        Decimal          @default(0) @db.Decimal(14, 2)
  grandTotal       Decimal          @default(0) @db.Decimal(14, 2)
  notes            String?
  expectedDelivery DateTime?
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  supplier      Supplier?            @relation(fields: [supplierId], references: [id])
  entity        Entity               @relation(fields: [entityId], references: [id])
  createdBy     User                 @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy    User?                @relation("ApprovedBy", fields: [approvedById], references: [id])
  lineItems     POLineItem[]
  freeTextItems POLineItemFreetext[]
  refundItems   POLineItemRefund[]
  rmIssuances   PORmIssuance[]
  grns          GRN[]
  payments      Payment[]

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
  @@index([tenantId, purchaseType])
  @@map("purchase_orders")
}

model POLineItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  taxRate         Decimal  @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal  @db.Decimal(14, 2)
  receivedQty     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
  grnLineItems  GRNLineItem[]

  @@map("po_line_items")
}

model POLineItemFreetext {
  id              String   @id @default(cuid())
  purchaseOrderId String
  description     String
  quantity        Int      @default(1)
  unitPrice       Decimal  @db.Decimal(12, 2)
  taxRate         Decimal  @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal  @db.Decimal(14, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("po_line_items_freetext")
}

model POLineItemRefund {
  id              String   @id @default(cuid())
  purchaseOrderId String
  customerName    String
  orderNumber     String?
  reason          String
  amount          Decimal  @db.Decimal(12, 2)
  refundMode      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("po_line_items_refunds")
}

model PORmIssuance {
  id              String   @id @default(cuid())
  purchaseOrderId String
  issuanceNumber  String
  issuedAt        DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  items         PORmIssuanceItem[]

  @@map("po_rm_issuances")
}

model PORmIssuanceItem {
  id         String   @id @default(cuid())
  issuanceId String
  productId  String
  quantity   Int
  batchId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  issuance       PORmIssuance    @relation(fields: [issuanceId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id])
  inventoryBatch InventoryBatch? @relation(fields: [batchId], references: [id])

  @@map("po_rm_issuance_items")
}

// ============================================
// INVENTORY TABLES
// ============================================

model GRN {
  id              String   @id @default(cuid())
  tenantId        String
  grnNumber       String
  purchaseOrderId String
  receivedAt      DateTime @default(now())
  notes           String?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  createdBy     User          @relation("GRNCreatedBy", fields: [createdById], references: [id])
  lineItems     GRNLineItem[]

  @@unique([tenantId, grnNumber])
  @@index([tenantId])
  @@map("grns")
}

model GRNLineItem {
  id           String         @id @default(cuid())
  grnId        String
  poLineItemId String
  receivedQty  Int
  acceptedQty  Int
  rejectedQty  Int            @default(0)
  condition    GoodsCondition @default(good)
  batchNumber  String?
  expiryDate   DateTime?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  grn        GRN        @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poLineItem POLineItem @relation(fields: [poLineItemId], references: [id])

  @@map("grn_line_items")
}

model InventoryBatch {
  id          String    @id @default(cuid())
  tenantId    String
  productId   String
  batchNumber String
  quantity    Int       @default(0)
  costPrice   Decimal   @db.Decimal(12, 2)
  expiryDate  DateTime?
  locationId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  product         Product            @relation(fields: [productId], references: [id])
  stockLedger     StockLedger[]
  rmIssuanceItems PORmIssuanceItem[]
  outflowItems    OutflowItem[]

  @@unique([tenantId, productId, batchNumber])
  @@index([tenantId, productId])
  @@map("inventory_batches")
}

model StockLedger {
  id            String       @id @default(cuid())
  tenantId      String
  productId     String
  batchId       String?
  movementType  MovementType
  quantity      Int
  referenceId   String?
  referenceType String?
  notes         String?
  createdAt     DateTime     @default(now())

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  inventoryBatch InventoryBatch? @relation(fields: [batchId], references: [id])

  @@index([tenantId, productId])
  @@index([tenantId, movementType])
  @@map("stock_ledger")
}

model InventoryOutflow {
  id             String      @id @default(cuid())
  tenantId       String
  outflowNumber  String
  outflowType    OutflowType
  entityId       String
  salesChannelId String?
  orderReference String?
  notes          String?
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  entity       Entity             @relation(fields: [entityId], references: [id])
  salesChannel SalesChannel?      @relation(fields: [salesChannelId], references: [id])
  createdBy    User               @relation(fields: [createdById], references: [id])
  items        OutflowItem[]
  packaging    OutflowPackaging[]

  @@unique([tenantId, outflowNumber])
  @@index([tenantId])
  @@map("inventory_outflows")
}

model OutflowItem {
  id        String   @id @default(cuid())
  outflowId String
  productId String
  batchId   String?
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outflow        InventoryOutflow @relation(fields: [outflowId], references: [id], onDelete: Cascade)
  product        Product          @relation(fields: [productId], references: [id])
  inventoryBatch InventoryBatch?  @relation(fields: [batchId], references: [id])

  @@map("outflow_items")
}

model OutflowPackaging {
  id          String   @id @default(cuid())
  outflowId   String
  description String
  quantity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outflow InventoryOutflow @relation(fields: [outflowId], references: [id], onDelete: Cascade)

  @@map("outflow_packaging")
}

model StockAdjustment {
  id             String         @id @default(cuid())
  tenantId       String
  adjustmentType AdjustmentType
  productId      String
  batchId        String?
  quantity       Int
  reason         String
  approvedById   String?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy User   @relation(fields: [createdById], references: [id])

  @@index([tenantId])
  @@map("stock_adjustments")
}

// ============================================
// PRODUCTION TABLES
// ============================================

model Production {
  id               String           @id @default(cuid())
  tenantId         String
  productionNumber String
  productionType   ProductionType
  status           ProductionStatus @default(planned)
  outputProductId  String?
  outputQuantity   Int?
  startDate        DateTime?
  endDate          DateTime?
  notes            String?
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id])
  createdBy User                 @relation("ProductionCreatedBy", fields: [createdById], references: [id])
  materials ProductionMaterial[]

  @@unique([tenantId, productionNumber])
  @@index([tenantId])
  @@map("productions")
}

model ProductionMaterial {
  id           String   @id @default(cuid())
  productionId String
  productId    String
  quantity     Int
  batchId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  production Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("production_materials")
}

// ============================================
// FINANCE TABLES
// ============================================

model Payment {
  id               String        @id @default(cuid())
  tenantId         String
  paymentNumber    String
  purchaseOrderId  String?
  supplierId       String?
  entityId         String
  paymentModeId    String?
  externalVendorId String?
  amount           Decimal       @db.Decimal(14, 2)
  paymentDate      DateTime
  status           PaymentStatus @default(pending)
  reference        String?
  notes            String?
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrder  PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  entity         Entity          @relation(fields: [entityId], references: [id])
  paymentMode    PaymentMode?    @relation(fields: [paymentModeId], references: [id])
  externalVendor ExternalVendor? @relation(fields: [externalVendorId], references: [id])
  createdBy      User            @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  approvedBy     User?           @relation("PaymentApprovedBy", fields: [approvedById], references: [id])

  @@unique([tenantId, paymentNumber])
  @@index([tenantId])
  @@map("payments")
}

model MarketplaceSettlement {
  id             String   @id @default(cuid())
  tenantId       String
  salesChannelId String
  settlementDate DateTime
  grossAmount    Decimal  @db.Decimal(14, 2)
  fees           Decimal  @default(0) @db.Decimal(14, 2)
  netAmount      Decimal  @db.Decimal(14, 2)
  reference      String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  salesChannel SalesChannel @relation(fields: [salesChannelId], references: [id])

  @@index([tenantId])
  @@map("marketplace_settlements")
}

model CustomerInvoice {
  id            String    @id @default(cuid())
  tenantId      String
  invoiceNumber String
  customerName  String
  customerEmail String?
  customerPhone String?
  totalAmount   Decimal   @db.Decimal(14, 2)
  taxAmount     Decimal   @default(0) @db.Decimal(14, 2)
  grandTotal    Decimal   @db.Decimal(14, 2)
  invoiceDate   DateTime
  dueDate       DateTime?
  status        String    @default("unpaid")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id])
  items  CustomerInvoiceItem[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@map("customer_invoices")
}

model CustomerInvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount Decimal  @db.Decimal(14, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice CustomerInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("customer_invoice_items")
}

model CustomerCredit {
  id            String   @id @default(cuid())
  tenantId      String
  customerName  String
  customerEmail String?
  customerPhone String?
  balance       Decimal  @default(0) @db.Decimal(14, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  transactions CreditTransaction[]

  @@index([tenantId])
  @@map("customer_credits")
}

model CreditTransaction {
  id               String   @id @default(cuid())
  customerCreditId String
  transactionType  String
  amount           Decimal  @db.Decimal(14, 2)
  reference        String?
  notes            String?
  createdAt        DateTime @default(now())

  customerCredit CustomerCredit @relation(fields: [customerCreditId], references: [id], onDelete: Cascade)

  @@map("credit_transactions")
}

model ApprovalAuditLog {
  id           String         @id @default(cuid())
  tenantId     String
  approvalType ApprovalType
  referenceId  String
  action       ApprovalAction
  userId       String
  reason       String?
  createdAt    DateTime       @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, approvalType])
  @@map("approval_audit_log")
}
