generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                     String                  @id @default(cuid())
  name                   String
  slug                   String                  @unique
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  approvalAuditLogs      ApprovalAuditLog[]
  customerCredits        CustomerCredit[]
  customerInvoices       CustomerInvoice[]
  entities               Entity[]
  externalVendors        ExternalVendor[]
  fabrics                Fabric[]
  finishedProducts       FinishedProduct[]
  grns                   GRN[]
  inventoryBatches       InventoryBatch[]
  inventoryOutflows      InventoryOutflow[]
  marketplaceSettlements MarketplaceSettlement[]
  mediaFiles             MediaFile[]
  packaging              Packaging[]
  paymentModes           PaymentMode[]
  payments               Payment[]
  productCategories      ProductCategory[]
  productions            Production[]
  products               Product[]
  purchaseOrders         PurchaseOrder[]
  purchaseTypes          PurchaseTypeConfig[]
  rawMaterials           RawMaterial[]
  salesChannels          SalesChannel[]
  stockAdjustments       StockAdjustment[]
  stockLedger            StockLedger[]
  styles                 Style[]
  suppliers              Supplier[]
  supplierPricings       SupplierPricing[]
  users                  User[]
  // Sales module relations
  salesOrders            SalesOrder[]
  salesPlatforms         SalesPlatform[]
  salesWarehouses        SalesWarehouse[]
  warehouseStocks        WarehouseStock[]
  salesStockMovements    SalesStockMovement[]
  inventoryDiscrepancies InventoryDiscrepancy[]
  salesRevenues          SalesRevenue[]
  expenses               Expense[]
  platformFees           PlatformFee[]
  gstTransactions        GstTransaction[]
  cogsRecords            CogsRecord[]
  plSummaries            PlSummary[]
  syncLogs               SyncLog[]
  webhookEvents          WebhookEvent[]
  amazonBusinessMetrics  AmazonBusinessMetric[]

  @@map("tenants")
}

model User {
  id                     String             @id @default(cuid())
  tenantId               String
  email                  String             @unique
  name                   String
  role                   String             @default("user")
  isSuperAdmin           Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  isActive               Boolean            @default(true)
  supabaseUserId         String?            @unique
  approvalActions        ApprovalAuditLog[]
  createdGRNs            GRN[]              @relation("GRNCreatedBy")
  inventoryOutflows      InventoryOutflow[]
  approvedPayments       Payment[]          @relation("PaymentApprovedBy")
  createdPayments        Payment[]          @relation("PaymentCreatedBy")
  executedPayments       Payment[]          @relation("PaymentExecutedBy")
  createdProductions     Production[]       @relation("ProductionCreatedBy")
  completedProductions   Production[]       @relation("ProductionCompletedBy")
  approvedPurchaseOrders PurchaseOrder[]    @relation("ApprovedBy")
  createdPurchaseOrders  PurchaseOrder[]    @relation("CreatedBy")
  reconciledPurchaseOrders PurchaseOrder[]  @relation("ReconciledBy")
  stockAdjustments       StockAdjustment[]
  permissions            UserPermission[]
  tenant                 Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("users")
}

model UserPermission {
  id              String          @id @default(cuid())
  userId          String
  module          String
  subModule       String?
  permissionLevel PermissionLevel @default(none)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module, subModule])
  @@map("user_permissions")
}

model PurchaseTypeConfig {
  id                String       @id @default(cuid())
  tenantId          String
  purchaseType      PurchaseType
  name              String
  prefix            String
  allowedEntryModes EntryMode[]
  trackInventory    Boolean      @default(false)
  requiresApproval  Boolean      @default(true)
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  tenant            Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, purchaseType])
  @@map("purchase_types")
}

model SalesChannel {
  id                     String                  @id @default(cuid())
  tenantId               String
  name                   String
  code                   String
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  inventoryOutflows      InventoryOutflow[]
  marketplaceSettlements MarketplaceSettlement[]
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@map("sales_channels")
}

model Entity {
  id                String             @id @default(cuid())
  tenantId          String
  name              String
  type              EntityType
  isExternal        Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  finishedProducts  FinishedProduct[]
  inventoryOutflows InventoryOutflow[]
  paymentModes      PaymentMode[]
  payments          Payment[]
  purchaseOrders    PurchaseOrder[]

  @@unique([tenantId, name])
  @@map("entities")
}

model PaymentMode {
  id        String    @id @default(cuid())
  entityId  String
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenantId  String?
  entity    Entity    @relation(fields: [entityId], references: [id])
  Tenant    Tenant?   @relation(fields: [tenantId], references: [id])
  payments  Payment[]

  @@unique([entityId, name])
  @@map("payment_modes")
}

model ExternalVendor {
  id         String             @id @default(cuid())
  tenantId   String
  name       String
  code       String
  vendorType ExternalVendorType
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  payments   Payment[]

  @@unique([tenantId, code])
  @@map("external_vendors")
}

model Supplier {
  id                String            @id @default(cuid())
  tenantId          String
  name              String
  code              String
  email             String?
  phone             String?
  address           String?
  gstNumber         String?
  panNumber         String?
  bankName          String?
  bankAccountNumber String?
  bankIfscCode      String?
  paymentTerms      String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  supplyCategories  String[]          @default([])
  fabrics           Fabric[]
  packaging         Packaging[]
  payments          Payment[]
  purchaseOrders    PurchaseOrder[]
  rawMaterials      RawMaterial[]
  contacts          SupplierContact[]
  grns              GRN[]
  pricings          SupplierPricing[]
  tenant            Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("suppliers")
}

model SupplierContact {
  id         String   @id @default(cuid())
  supplierId String
  name       String
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@map("supplier_contacts")
}

model SupplierPricing {
  id                String    @id @default(cuid())
  tenantId          String
  supplierId        String
  productId         String?
  productType       String?   // 'finished', 'fabric', 'raw_material', 'packaging'
  unitPrice         Decimal?  @db.Decimal(15, 2)
  jobWorkRate       Decimal?  @db.Decimal(15, 2)
  directPurchaseRate Decimal? @db.Decimal(15, 2)
  currency          String    @default("INR")
  minQty            Int?
  validFrom         DateTime?
  validTo           DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  supplier          Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([tenantId, supplierId, productId, productType])
  @@index([tenantId, supplierId])
  @@index([productId, productType])
  @@map("supplier_pricing")
}

model ProductCategory {
  id        String            @id @default(cuid())
  tenantId  String
  name      String
  level     Int               @default(1)
  parentId  String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  parent    ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  ProductCategory[] @relation("CategoryHierarchy")
  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  products  Product[]

  @@index([tenantId])
  @@map("product_categories")
}

model Product {
  id                  String               @id @default(cuid())
  tenantId            String
  sku                 String
  name                String
  description         String?
  categoryId          String?
  unit                String               @default("pcs")
  hsnCode             String?
  gstRate             Decimal?             @db.Decimal(5, 2)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  //inventoryBatches    InventoryBatch[]
  category            ProductCategory?     @relation(fields: [categoryId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  //stockLedger         StockLedger[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

model PurchaseOrder {
  id               String               @id @default(cuid())
  tenantId         String
  poNumber         String
  purchaseType     PurchaseType
  supplierId       String?
  entityId         String?
  status           POStatus             @default(draft)
  entryMode        EntryMode
  rawMaterialMode  RawMaterialMode?
  totalAmount      Decimal              @default(0) @db.Decimal(14, 2)
  taxAmount        Decimal              @default(0) @db.Decimal(14, 2)
  grandTotal       Decimal              @default(0) @db.Decimal(14, 2)
  notes            String?
  expectedDelivery DateTime?
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  rejectionReason  String?
  // Reconciliation fields
  invoiceNumber        String?
  invoiceDate          DateTime?
  invoiceAmount        Decimal?             @db.Decimal(14, 2)
  invoiceAttachment    String?
  grnAttachment        String?
  transportCharges     Decimal?             @db.Decimal(14, 2)
  reconciliationNotes  String?
  reconciledById       String?
  reconciledAt         DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  grns             GRN[]
  payments         Payment[]
  lineItems        POLineItem[]
  freeTextItems    POLineItemFreetext[]
  refundItems      POLineItemRefund[]
  rmIssuances      PORmIssuance[]
  approvedBy       User?                @relation("ApprovedBy", fields: [approvedById], references: [id])
  createdBy        User                 @relation("CreatedBy", fields: [createdById], references: [id])
  reconciledBy     User?                @relation("ReconciledBy", fields: [reconciledById], references: [id])
  entity           Entity?              @relation(fields: [entityId], references: [id])
  supplier         Supplier?            @relation(fields: [supplierId], references: [id])
  tenant           Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, poNumber])
  @@index([tenantId, status])
  @@index([tenantId, purchaseType])
  @@map("purchase_orders")
}

model POLineItem {
  id              String   @id @default(cuid())
  poId            String
  purchaseOrder   PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  
  // ✅ NO foreign keys - just plain strings
  productId       String?
  productType     String?  // 'finished', 'fabric', 'raw_material', 'packaging'
  
  quantity        Decimal   @db.Decimal(15,3)
  unitPrice       Decimal   @db.Decimal(15,2)
  taxRate         Decimal   @db.Decimal(5,2)
  taxAmount       Decimal   @db.Decimal(15,2)
  totalAmount     Decimal   @db.Decimal(15,2)
  
  createdAt       DateTime  @default(now())
  
  // Keep this relation
  grnLineItems    GRNLineItem[]
  
  @@map("po_line_items")
  @@index([poId])
  @@index([productId])
}

model POLineItemFreetext {
  id              String        @id @default(cuid())
  purchaseOrderId String
  description     String
  quantity        Int           @default(1)
  unitPrice       Decimal       @db.Decimal(12, 2)
  taxRate         Decimal       @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(14, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("po_line_items_freetext")
}

model POLineItemRefund {
  id              String        @id @default(cuid())
  purchaseOrderId String
  customerName    String
  orderNumber     String?
  reason          String
  amount          Decimal       @db.Decimal(12, 2)
  refundMode      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("po_line_items_refunds")
}

model PORmIssuance {
  id              String             @id @default(cuid())
  purchaseOrderId String
  issuanceNumber  String
  issuedAt        DateTime           @default(now())
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  items           PORmIssuanceItem[]
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("po_rm_issuances")
}

model PORmIssuanceItem {
  id             String          @id @default(cuid())
  issuanceId     String
  productId      String?
  productType    String?         // 'finished', 'fabric', 'raw_material', 'packaging'
  quantity       Int
  batchId        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  inventoryBatch InventoryBatch? @relation(fields: [batchId], references: [id])
  issuance       PORmIssuance    @relation(fields: [issuanceId], references: [id], onDelete: Cascade)

  @@map("po_rm_issuance_items")
}

model GRN {
  id                String         @id @default(cuid())
  tenantId          String
  grnNumber         String         @unique
  
  // PO Reference
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  poNumber          String
  
  // Supplier Reference
  supplierId        String?
  supplier          Supplier?       @relation(fields: [supplierId], references: [id])
  
  // GRN Details
  grnDate           DateTime
  receivedBy        String
  deliveryChallan   String?
  vehicleNumber     String?
  notes             String?
  status            String         @default("completed")
  
  // Audit
  createdBy         String
  createdById       String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  // Relations
  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  user              User           @relation("GRNCreatedBy", fields: [createdById], references: [id])
  lineItems         GRNLineItem[]
  inventoryBatches  InventoryBatch[]
  
  @@map("grns")
  @@index([tenantId])
  @@index([purchaseOrderId])
  @@index([supplierId])
}

model GRNLineItem {
  id           String         @id @default(cuid())
  grnId        String
  poLineItemId String
  receivedQty  Int
  acceptedQty  Int
  rejectedQty  Int            @default(0)
  condition    GoodsCondition @default(good)
  batchNumber  String?
  expiryDate   DateTime?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  grn          GRN            @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poLineItem   POLineItem     @relation(fields: [poLineItemId], references: [id])

  @@map("grn_line_items")
}

model InventoryBatch {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  
  // Polymorphic product reference (no strict FK)
  productId       String?
  productType     String?  // 'finished', 'fabric', 'raw_material', 'packaging'
  sku             String?
  
  batchNumber     String
  
  // Source tracking
  grnId           String?
  grn             GRN?      @relation(fields: [grnId], references: [id])
  productionId    String?
  adjustmentId    String?
  
  // Quantities
  initialQty      Decimal   @db.Decimal(15,3)
  currentQty      Decimal   @db.Decimal(15,3)
  
  status          String    @default("active")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  stockLedger     StockLedger[]
  outflowItems    OutflowItem[]
  adjustments     StockAdjustment[]
  rmIssuanceItems PORmIssuanceItem[]
  
  @@map("inventory_batches")
  @@index([tenantId, sku])
  @@index([tenantId, productType, status])
  @@index([productId])
  @@index([grnId])
}

model StockLedger {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  
  // Polymorphic product reference (no strict FK)
  productId       String?
  productType     String?
  sku             String?
  
  // Batch reference
  batchId         String?
  batch           InventoryBatch? @relation(fields: [batchId], references: [id])
  batchNumber     String?
  
  // Movement details
  movementType    String   // 'grn', 'sale', 'production_in', 'production_out', 'adjustment'
  referenceType   String   // 'grn', 'sale_order', 'production', 'adjustment'
  referenceId     String
  referenceNumber String?
  
  // Quantities
  qtyIn           Decimal   @db.Decimal(15,3)
  qtyOut          Decimal   @db.Decimal(15,3)
  batchBalance    Decimal   @db.Decimal(15,3)
  skuBalance      Decimal   @db.Decimal(15,3)
  
  notes           String?   @db.Text
  createdBy       String
  createdAt       DateTime  @default(now())
  
  @@map("stock_ledger")
  @@index([tenantId, sku])
  @@index([tenantId, createdAt])
  @@index([tenantId, productType, createdAt])
  @@index([productId])
  @@index([batchId])
  @@index([referenceType, referenceId])
}

model InventoryOutflow {
  id             String             @id @default(cuid())
  tenantId       String
  outflowNumber  String             @unique
  outflowType    OutflowType
  entityId       String?
  salesChannelId String?
  orderReference String?

  // Recipient
  recipientName  String?
  recipientType  String?            // 'customer', 'influencer', 'supplier', 'internal'

  // Dates & status
  outflowDate    DateTime           @default(now())
  status         String             @default("completed")

  // Totals
  totalItems     Int                @default(0)
  totalQuantity  Decimal            @db.Decimal(15,3) @default(0)

  notes          String?            @db.Text
  createdBy      String?
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // Relations
  user           User               @relation(fields: [createdById], references: [id])
  entity         Entity?            @relation(fields: [entityId], references: [id])
  salesChannel   SalesChannel?      @relation(fields: [salesChannelId], references: [id])
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  items          OutflowItem[]
  packaging      OutflowPackaging[]

  @@index([tenantId])
  @@index([outflowType])
  @@index([outflowDate])
  @@map("inventory_outflows")
}

model OutflowItem {
  id             String           @id @default(cuid())
  outflowId      String

  // Product details (polymorphic)
  productId      String?
  productType    String?          // 'finished', 'fabric', 'raw_material', 'packaging'
  sku            String?
  productName    String?

  // Batch tracking
  batchId        String
  batchNumber    String?

  // Quantity & cost
  quantity       Decimal          @db.Decimal(15,3)
  reason         String?          @db.Text

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  inventoryBatch InventoryBatch   @relation(fields: [batchId], references: [id])
  outflow        InventoryOutflow @relation(fields: [outflowId], references: [id], onDelete: Cascade)

  @@index([outflowId])
  @@index([batchId])
  @@map("outflow_items")
}

model OutflowPackaging {
  id          String           @id @default(cuid())
  outflowId   String
  description String
  quantity    Int
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  outflow     InventoryOutflow @relation(fields: [outflowId], references: [id], onDelete: Cascade)

  @@map("outflow_packaging")
}

model StockAdjustment {
  id                 String         @id @default(cuid())
  tenantId           String
  adjustmentNumber   String         @unique
  adjustmentType     AdjustmentType

  // Product details (polymorphic)
  productId          String?
  productType        String?
  sku                String?
  productName        String?

  // Batch tracking
  batchId            String
  batch              InventoryBatch @relation(fields: [batchId], references: [id])
  batchNumber        String?

  // Quantities
  systemQuantity     Decimal        @db.Decimal(15,3)
  actualQuantity     Decimal        @db.Decimal(15,3)
  adjustmentQuantity Decimal        @db.Decimal(15,3)

  reason             String
  adjustmentDate     DateTime       @default(now())
  notes              String?        @db.Text
  status             String         @default("completed")

  // Audit
  createdBy          String?
  createdById        String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // Relations
  user               User           @relation(fields: [createdById], references: [id])
  tenant             Tenant         @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([batchId])
  @@map("stock_adjustments")
}

model Production {
  id               String               @id @default(cuid())
  tenantId         String
  productionNumber String
  productionType   ProductionType
  status           ProductionStatus     @default(planned)

  // Output product
  outputProductId  String?
  outputQuantity   Int?
  sku              String?
  productName      String?

  // Quantities
  plannedQty       Decimal?             @db.Decimal(15,3)
  actualQty        Decimal?             @db.Decimal(15,3)
  rejectedQty      Decimal?             @db.Decimal(15,3) @default(0)
  wasteQty         Decimal?             @db.Decimal(15,3) @default(0)

  // Dates
  startDate        DateTime?
  endDate          DateTime?
  targetDate       DateTime?
  completionDate   DateTime?

  // Location
  productionLine   String?
  location         String?

  // Costs
  materialCost     Decimal?             @db.Decimal(15,2)
  laborCost        Decimal?             @db.Decimal(15,2)
  overheadCost     Decimal?             @db.Decimal(15,2)
  totalCost        Decimal?             @db.Decimal(15,2)
  costPerUnit      Decimal?             @db.Decimal(15,2)

  notes            String?              @db.Text

  // Audit
  createdById      String
  completedBy      String?
  completedById    String?

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  materials        ProductionMaterial[]
  createdBy        User                 @relation("ProductionCreatedBy", fields: [createdById], references: [id])
  completedByUser  User?                @relation("ProductionCompletedBy", fields: [completedById], references: [id])
  tenant           Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, productionNumber])
  @@index([tenantId])
  @@index([status])
  @@map("productions")
}

model ProductionMaterial {
  id           String     @id @default(cuid())
  productionId String
  productId    String?
  productType  String?    // 'finished', 'fabric', 'raw_material', 'packaging'
  quantity     Int
  batchId      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  production   Production @relation(fields: [productionId], references: [id], onDelete: Cascade)

  @@map("production_materials")
}

model Payment {
  id               String          @id @default(cuid())
  tenantId         String
  paymentNumber    String
  purchaseOrderId  String?
  supplierId       String?
  entityId         String
  paymentModeId    String?
  externalVendorId String?
  amount           Decimal         @db.Decimal(14, 2)
  paymentDate      DateTime
  status           PaymentStatus   @default(pending)
  reference        String?
  notes            String?
  // Invoice details (from reconciliation)
  invoiceNumber        String?
  invoiceDate          DateTime?
  invoiceAmount        Decimal?        @db.Decimal(14, 2)
  invoiceAttachment    String?
  // Execution details
  transactionReference String?
  amountPaid           Decimal?        @db.Decimal(14, 2)
  tdsDeducted          Decimal?        @default(0) @db.Decimal(14, 2)
  netAmountPaid        Decimal?        @db.Decimal(14, 2)
  paymentProof         String?
  executionRemarks     String?
  rejectionReason      String?
  // Audit fields
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  executedById     String?
  executedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
