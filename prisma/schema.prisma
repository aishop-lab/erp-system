// ============================================================
// SALES MODULE
// ============================================================

model SalesPlatform {
  id                  String                @id @default(cuid())
  tenantId            String
  name                String                // amazon, shopify, myntra, direct
  displayName         String
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  credentials         PlatformCredential[]
  platformMappings    PlatformMapping[]
  salesOrders         SalesOrder[]
  salesRevenues       SalesRevenue[]
  platformFees        PlatformFee[]
  salesWarehouses     SalesWarehouse[]
  syncLogs            SyncLog[]
  webhookEvents       WebhookEvent[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("sales_platforms")
}

model PlatformCredential {
  id              String        @id @default(cuid())
  tenantId        String
  platformId      String
  credentials     Json          @default("{}")
  isConnected     Boolean       @default(false)
  lastVerifiedAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  platform        SalesPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platformId])
  @@map("platform_credentials")
}

model PlatformMapping {
  id                 String           @id @default(cuid())
  tenantId           String
  finishedProductId  String?
  platformId         String
  externalProductId  String?
  externalVariantId  String?
  externalSku        String?
  asin               String?
  listingUrl         String?
  isActive           Boolean          @default(true)
  metadata           Json             @default("{}")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  finishedProduct    FinishedProduct? @relation(fields: [finishedProductId], references: [id])
  platform           SalesPlatform    @relation(fields: [platformId], references: [id])

  @@unique([tenantId, finishedProductId, platformId])
  @@index([tenantId])
  @@index([asin])
  @@index([externalSku])
  @@map("platform_mappings")
}

model SalesOrder {
  id                 String              @id @default(cuid())
  tenantId           String
  platformId         String
  orderNumber        String
  externalOrderId    String?
  sourceId           String?             // Original UUID from source system
  status             SalesOrderStatus    @default(pending)
  customerName       String?
  customerEmail      String?
  customerPhone      String?
  shippingAddress    Json?
  billingAddress     Json?
  subtotal           Decimal             @default(0) @db.Decimal(12, 2)
  discount           Decimal             @default(0) @db.Decimal(12, 2)
  shippingCharge     Decimal             @default(0) @db.Decimal(12, 2)
  taxAmount          Decimal             @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal             @default(0) @db.Decimal(12, 2)
  currency           String              @default("INR")
  paymentStatus      String              @default("pending")
  fulfillmentStatus  String              @default("unfulfilled")
  trackingNumber     String?
  trackingUrl        String?
  courier            String?
  platformMetadata   Json                @default("{}")
  notes              String?
  orderedAt          DateTime?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  platform           SalesPlatform       @relation(fields: [platformId], references: [id])
  items              SalesOrderItem[]
  salesPayments      SalesPayment[]
  salesRevenue       SalesRevenue?
  cogsRecords        CogsRecord[]
  platformFees       PlatformFee[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, platformId, status])
  @@index([tenantId, status, orderedAt])
  @@index([platformId])
  @@index([status])
  @@index([orderedAt])
  @@index([externalOrderId])
  @@index([sourceId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id                String          @id @default(cuid())
  orderId           String
  tenantId          String
  finishedProductId String?
  productName       String
  variantName       String?
  sku               String?
  quantity          Int             @default(1)
  unitPrice         Decimal         @default(0) @db.Decimal(12, 2)
  discount          Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal         @default(0) @db.Decimal(12, 2)
  total             Decimal         @default(0) @db.Decimal(12, 2)
  metadata          Json            @default("{}")
  sourceId          String?         // Original UUID from source system
  createdAt         DateTime        @default(now())
  order             SalesOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  finishedProduct   FinishedProduct? @relation(fields: [finishedProductId], references: [id])

  @@index([orderId])
  @@index([finishedProductId])
  @@map("sales_order_items")
}

model SalesPayment {
  id            String     @id @default(cuid())
  orderId       String
  tenantId      String
  amount        Decimal    @db.Decimal(12, 2)
  method        String?
  transactionId String?
  status        String     @default("completed")
  paidAt        DateTime?
  metadata      Json       @default("{}")
  sourceId      String?    // Original UUID from source system
  createdAt     DateTime   @default(now())
  order         SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("sales_payments")
}

// ============================================================
// SALES INVENTORY (Warehouse-based, separate from batch-based procurement inventory)
// ============================================================

model SalesWarehouse {
  id              String               @id @default(cuid())
  tenantId        String
  name            String
  code            String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  isFba           Boolean              @default(false)
  platformId      String?
  isActive        Boolean              @default(true)
  sourceId        String?              // Original UUID from source system
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  platform        SalesPlatform?       @relation(fields: [platformId], references: [id])
  warehouseStocks WarehouseStock[]
  stockMovements  SalesStockMovement[]
  discrepancies   InventoryDiscrepancy[] @relation("DiscrepancyWarehouse")
  fbaDiscrepancies InventoryDiscrepancy[] @relation("DiscrepancyFbaWarehouse")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("sales_warehouses")
}

model WarehouseStock {
  id                String          @id @default(cuid())
  tenantId          String
  warehouseId       String
  finishedProductId String?
  sku               String?
  qtyOnHand         Int             @default(0)
  qtyReserved       Int             @default(0)
  lastSyncedAt      DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  warehouse         SalesWarehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  finishedProduct   FinishedProduct? @relation(fields: [finishedProductId], references: [id])

  @@unique([warehouseId, sku])
  @@index([tenantId])
  @@map("warehouse_stocks")
}

model SalesStockMovement {
  id              String         @id @default(cuid())
  tenantId        String
  warehouseId     String
  sku             String?
  movementType    String         // purchase, sales, transfer_in, transfer_out, adjustment, return, damage, fba_sync
  quantity        Int
  referenceType   String?
  referenceId     String?
  notes           String?
  createdBy       String?
  createdAt       DateTime       @default(now())
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  warehouse       SalesWarehouse @relation(fields: [warehouseId], references: [id])

  @@index([tenantId])
  @@index([warehouseId])
  @@index([createdAt])
  @@map("sales_stock_movements")
}

model InventoryDiscrepancy {
  id               String          @id @default(cuid())
  tenantId         String
  sku              String?
  warehouseId      String
  fbaWarehouseId   String?
  systemQty        Int
  physicalQty      Int
  status           String          @default("open") // open, investigating, resolved, dismissed
  severity         String?         // none, minor, moderate, major
  reason           String?
  investigationNotes String?
  resolutionNotes  String?
  resolvedBy       String?
  resolvedAt       DateTime?
  detectedAt       DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  warehouse        SalesWarehouse  @relation("DiscrepancyWarehouse", fields: [warehouseId], references: [id])
  fbaWarehouse     SalesWarehouse? @relation("DiscrepancyFbaWarehouse", fields: [fbaWarehouseId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("inventory_discrepancies")
}

// ============================================================
// SALES FINANCE
// ============================================================

model SalesRevenue {
  id           String        @id @default(cuid())
  tenantId     String
  orderId      String        @unique
  platformId   String
  grossRevenue Decimal       @default(0) @db.Decimal(12, 2)
  discount     Decimal       @default(0) @db.Decimal(12, 2)
  netRevenue   Decimal       @default(0) @db.Decimal(12, 2)
  taxCollected Decimal       @default(0) @db.Decimal(12, 2)
  date         DateTime
  sourceId     String?
  createdAt    DateTime      @default(now())
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  order        SalesOrder    @relation(fields: [orderId], references: [id])
  platform     SalesPlatform @relation(fields: [platformId], references: [id])

  @@index([tenantId])
  @@index([date])
  @@index([platformId])
  @@map("sales_revenues")
}

model Expense {
  id            String   @id @default(cuid())
  tenantId      String
  category      String
  subcategory   String?
  description   String
  amount        Decimal  @db.Decimal(12, 2)
  gstAmount     Decimal  @default(0) @db.Decimal(12, 2)
  gstRate       Decimal  @default(0) @db.Decimal(5, 2)
  vendor        String?
  invoiceNumber String?
  receiptUrl    String?
  date          DateTime
  isRecurring   Boolean  @default(false)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([date])
  @@index([category])
  @@map("expenses")
}

model PlatformFee {
  id          String        @id @default(cuid())
  tenantId    String
  orderId     String?
  platformId  String
  feeType     String
  amount      Decimal       @db.Decimal(12, 2)
  description String?
  date        DateTime
  metadata    Json          @default("{}")
  sourceId    String?
  createdAt   DateTime      @default(now())
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  order       SalesOrder?   @relation(fields: [orderId], references: [id])
  platform    SalesPlatform @relation(fields: [platformId], references: [id])

  @@index([tenantId])
  @@index([orderId])
  @@index([date])
  @@map("platform_fees")
}

model GstTransaction {
  id              String   @id @default(cuid())
  tenantId        String
  referenceType   String
  referenceId     String
  hsnCode         String?
  taxableAmount   Decimal  @db.Decimal(12, 2)
  cgstRate        Decimal  @default(0) @db.Decimal(5, 2)
  cgstAmount      Decimal  @default(0) @db.Decimal(12, 2)
  sgstRate        Decimal  @default(0) @db.Decimal(5, 2)
  sgstAmount      Decimal  @default(0) @db.Decimal(12, 2)
  igstRate        Decimal  @default(0) @db.Decimal(5, 2)
  igstAmount      Decimal  @default(0) @db.Decimal(12, 2)
  totalTax        Decimal  @db.Decimal(12, 2)
  transactionType String   // output, input
  date            DateTime
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([date])
  @@map("gst_transactions")
}

model CogsRecord {
  id                String          @id @default(cuid())
  tenantId          String
  orderItemId       String?
  finishedProductId String?
  sku               String?
  quantity          Int
  unitCost          Decimal         @db.Decimal(12, 2)
  totalCost         Decimal         @db.Decimal(12, 2)
  date              DateTime
  orderId           String?
  sourceId          String?
  createdAt         DateTime        @default(now())
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  order             SalesOrder?     @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@index([date])
  @@map("cogs_records")
}

model PlSummary {
  id                String   @id @default(cuid())
  tenantId          String
  periodStart       DateTime
  periodEnd         DateTime
  grossRevenue      Decimal  @default(0) @db.Decimal(14, 2)
  netRevenue        Decimal  @default(0) @db.Decimal(14, 2)
  cogs              Decimal  @default(0) @db.Decimal(14, 2)
  grossProfit       Decimal  @default(0) @db.Decimal(14, 2)
  platformFees      Decimal  @default(0) @db.Decimal(14, 2)
  shippingCosts     Decimal  @default(0) @db.Decimal(14, 2)
  otherExpenses     Decimal  @default(0) @db.Decimal(14, 2)
  totalExpenses     Decimal  @default(0) @db.Decimal(14, 2)
  netProfit         Decimal  @default(0) @db.Decimal(14, 2)
  marginPercentage  Decimal  @default(0) @db.Decimal(5, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, periodStart, periodEnd])
  @@index([tenantId])
  @@map("pl_summaries")
}

// ============================================================
// SYNC & MONITORING
// ============================================================

model SyncLog {
  id               String        @id @default(cuid())
  tenantId         String
  platformId       String
  syncType         String
  status           String        @default("running") // running, completed, failed, partial
  recordsProcessed Int           @default(0)
  recordsCreated   Int           @default(0)
  recordsUpdated   Int           @default(0)
  recordsFailed    Int           @default(0)
  errorMessage     String?
  metadata         Json          @default("{}")
  startedAt        DateTime      @default(now())
  completedAt      DateTime?
  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  platform         SalesPlatform @relation(fields: [platformId], references: [id])

  @@index([tenantId])
  @@index([platformId])
  @@index([status])
  @@map("sync_logs")
}

model WebhookEvent {
  id          String        @id @default(cuid())
  tenantId    String?
  platformId  String?
  eventType   String
  payload     Json
  processed   Boolean       @default(false)
  error       String?
  receivedAt  DateTime      @default(now())
  processedAt DateTime?
  tenant      Tenant?       @relation(fields: [tenantId], references: [id])
  platform    SalesPlatform? @relation(fields: [platformId], references: [id])

  @@index([processed])
  @@map("webhook_events")
}

model AmazonBusinessMetric {
  id                 String   @id @default(cuid())
  tenantId           String
  asin               String
  itemName           String?
  glanceViews        Int      @default(0)
  conversionRate     Float    @default(0)
  unitsShipped       Int      @default(0)
  avgSellingPrice    Float    @default(0)
  salesAmount        Float    @default(0)
  availableInventory Int      @default(0)
  reportDate         DateTime @default(now()) // When this data was pulled from Amazon
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, asin])
  @@index([tenantId])
  @@map("amazon_business_metrics")
}

